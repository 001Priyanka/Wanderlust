<% layout("./layouts/boilerplate") %>

<div class="container mt-4">

  <div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">

      <!-- Heading -->
      <h3 class="mb-4 fw-bold text-center">Listing Details</h3>

      <!-- Card -->
      <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

        <!-- Image -->
        <img 
          src="<%= listing.image %>" 
          class="card-img-top img-fluid"
          style="height: 400px; object-fit: cover;"
          alt="listing_image"
        >

        <!-- Body -->
        <div class="card-body p-4">

          <h4 class="fw-bold mb-2"><%= listing.title %></h4>

          <p class="text-muted mb-3" style="font-size: 1.05rem;">
            <%= listing.description %>
          </p>

          

          <!-- Price -->
          <p class="mb-2">
            <span class="fw-bold text-success fs-5">
              &#8377;<%= listing.price.toLocaleString("en-IN") %>
            </span>
            <span class="text-muted"> / night</span>
          </p>

          <!-- Location -->
          <p class="mb-0 text-secondary">
         <%= listing.location %>, <%= listing.country %>
          </p>

        </div>

        <!-- Buttons -->
        <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
        <div class="card-footer bg-white border-0 px-4 pb-4 pt-2 d-flex justify-content-between">

          <a 
            href="/listings/<%= listing._id %>/edit" 
            class="btn btn-outline-dark px-4 rounded-pill fw-semibold"
          >
             Edit
          </a>

          <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn btn-danger px-4 rounded-pill fw-semibold">
               Delete
            </button>
          </form>

        </div>
        <% } %>
      </div> <!-- End of Card -->

      <!-- Reviews Section -->
      <div class="mt-5 mb-5">
        <% if(currUser) { %>
        <hr class="mb-4 text-muted">
        <h4 class="fw-bold mb-4"><i class="bi bi-chat-square-text me-2"></i>Leave a Review</h4>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation shadow-sm p-4 rounded-4 bg-white border mb-5">
          <div class="mb-3 mt-3">
            <label class="form-label fw-semibold text-secondary">Rating</label>
            <fieldset class="starability-slot">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>
          <div class="mb-4">
            <label for="comment" class="form-label fw-semibold text-secondary">Comments</label>
            <textarea name="review[comment]" id="comment" cols="30" rows="3" class="form-control rounded-3 bg-light" required placeholder="Share your experience..."></textarea>
            <div class="invalid-feedback">Please add some comments for your review.</div>
          </div>
          <button class="btn btn-dark px-4 py-2 rounded-pill fw-semibold shadow-sm">Submit Review</button>
        </form>
        <% } %>

        <% if(listing.reviews && listing.reviews.length > 0) { %>
          <div class="row mt-4">
            <h5 class="fw-bold fs-4 mb-4">All Reviews</h3>
            <% for(let review of listing.reviews) { %>
              <div class="col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0 rounded-4">
                  <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-secondary rounded-circle text-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                            <i class="fw-bold"><%= review.author ? review.author.username.charAt(0).toUpperCase() : 'A' %></i>
                        </div>
                        <div class="ms-3">
                            <h6 class="card-title fw-bold mb-0">@<%= review.author ? review.author.username : 'Anonymous' %></h6>
                            <small class="text-muted"><%= new Date(review.createdAt).toLocaleDateString() %></small>
                        </div>
                        <div class="ms-auto">
                          <p class="starability-result" data-rating="<%= review.rating %>">
                            Rated: <%= review.rating %> stars
                          </p>
                        </div>
                    </div>
                    <p class="card-text text-secondary mb-1">
                      <%= review.comment %>
                    </p>
                    <% if(currUser && review.author && review.author._id.equals(currUser._id)) { %>
                    <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                        <button class="btn btn-sm btn-outline-danger mt-3 rounded-pill fw-semibold">Delete</button>
                    </form>
                    <% } %>
                  </div>
                </div>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>

    </div>
  </div>
  


</div>

